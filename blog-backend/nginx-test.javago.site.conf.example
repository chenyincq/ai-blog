# Nginx 反向代理示例：解决 https 访问接口 ERR_CONNECTION_RESET
# 原因：浏览器用 https 访问 :8081，但后端只提供 http，TLS 握手失败导致连接被重置。
# 做法：前端只请求同源 https://test.javago.site/api/*，由 Nginx 在 443 上终结 SSL 并转发到后端 http 端口。
#
# 使用步骤：
# 1. 将下方 server 块并入你已有的 test.javago.site 的 HTTPS server 中，或单独建站。
# 2. 确保本机已启动 blog-post-service (8081)、blog-auth-service (8082)。
# 3. 重新加载 Nginx: nginx -s reload
#
# 前端已配合修改：当页面为 https 且非 localhost 时，会自动请求同源 /api/posts、/api/auth、/api/friend-links，不再带 :8081/:8082。

server {
    listen 443 ssl http2;
    server_name test.javago.site;

    ssl_certificate     /path/to/your/fullchain.pem;
    ssl_certificate_key /path/to/your/privkey.pem;

    # 文章与友情链接服务 (8081)
    location /api/posts {
        proxy_pass http://127.0.0.1:8081;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
    location /api/friend-links {
        proxy_pass http://127.0.0.1:8081;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # 认证服务 (8082)
    location /api/auth {
        proxy_pass http://127.0.0.1:8082;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # 前端静态或开发代理（按你实际部署方式二选一）
    # 方式 A：已构建的静态文件
    # root /path/to/blog-frontend/dist;
    # index index.html;
    # location / { try_files $uri $uri/ /index.html; }

    # 方式 B：开发时反向到 Vite
    # location / {
    #     proxy_pass http://127.0.0.1:5173;
    #     proxy_http_version 1.1;
    #     proxy_set_header Upgrade $http_upgrade;
    #     proxy_set_header Connection "upgrade";
    #     proxy_set_header Host $host;
    # }
}
